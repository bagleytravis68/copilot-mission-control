{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bagleytravis68/copilot-mission-control/schemas/session-trace.schema.json",
  "title": "Mission Control session trace",
  "type": "object",
  "required": [
    "schemaVersion",
    "harness",
    "sessionId",
    "repoRoot",
    "status",
    "startedAt",
    "agents",
    "handoffs",
    "events"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "harness": {
      "type": "string"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "repoRoot": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "running",
        "complete",
        "error",
        "timeout",
        "aborted",
        "user_exit"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/agent"
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/handoff"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": [
        "name",
        "status",
        "startedAt",
        "handoffIds"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "running",
            "complete"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "handoffIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": [
        "handoffId",
        "fromAgent",
        "toAgent",
        "status",
        "createdAt"
      ],
      "properties": {
        "handoffId": {
          "type": "string"
        },
        "fromAgent": {
          "type": [
            "string",
            "null"
          ]
        },
        "toAgent": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "created",
            "running",
            "complete",
            "partial",
            "failed",
            "blocked"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": [
        "type",
        "at"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "agentName": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
